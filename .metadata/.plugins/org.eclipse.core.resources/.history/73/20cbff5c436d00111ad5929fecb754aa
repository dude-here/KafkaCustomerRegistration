package com.kafka.consumer;


import org.springframework.kafka.annotation.KafkaListener;

import org.springframework.stereotype.Component;

import com.kafka.consumer.dto.CustomerEvent;

import com.kafka.consumer.service.CustomerProcessingService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Slf4j
@Component
@RequiredArgsConstructor
public class CustomerEventConsumer {

    private final CustomerProcessingService service;

    @KafkaListener(
            topics = "${customer.topic.registration}",
            groupId = "customer-processing-group")
    public void consume(
            CustomerEvent event) {

        log.info(
                "Customer Event Received : {}",
                event.getCustomerCode());

        service.processCustomer(event);
    }
}